{
  "manifest_version": 3,
  "name": "EmailGuard AI",
  "version": "1.2",
  "description": "AI-powered phishing detection for Gmail",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://emailguard-ai.onrender.com/*",
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
